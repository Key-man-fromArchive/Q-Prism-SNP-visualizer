# .pcrd file decryption key (required for Bio-Rad .pcrd file support)
# Obtain this from your Bio-Rad CFX software installation.
# Without this key, .pcrd uploads will return an error.
PCRD_PASSWORD=

# Runtime persistence and authentication mode
DB_PATH=/app/data/snp_analyzer.db
SNP_AUTH_MODE=local
JWT_SECRET_KEY=change-this-to-a-random-32-plus-character-secret

# Upload and archive safety limits
MAX_UPLOAD_SIZE_MB=50
SESSION_RETENTION_DAYS=30
MAX_ZIP_ENTRIES=500
MAX_ZIP_UNCOMPRESSED_MB=100
MAX_ZIP_COMPRESSION_RATIO=100
